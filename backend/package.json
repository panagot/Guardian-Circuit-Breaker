{
  "name": "guardian-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Event-driven proof pipeline: Solana trigger -> Ika dWallet sign -> Ethereum Sepolia evacuation tx",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node ./scripts/start-prod.mjs",
    "start:single": "node dist/index.js",
    "lint": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "ika:sign-bridge": "node ./scripts/ika-http-sign-bridge.mjs"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
