# --- Server ---
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173

# --- Mode ---
# Set to "real" once *all* credentials below are populated.
# Any other value (or unset) keeps the pipeline in mock mode but with
# the real interfaces still wired end-to-end.
PIPELINE_MODE=mock

# When "1":
#   - POST /api/trigger returns 503 if vault/relayer/RPC are not configured for real Sepolia.
#   - A failed on-chain evacuate() does NOT fall back to a fake hash — the proof fails loudly.
# Recommended for prize / judge demos (every receipt must match sepolia.etherscan.io).
GUARDIAN_REQUIRE_REAL_SEPOLIA=

# --- Solana trigger source ---
# Public Solana cluster RPC (Devnet recommended for the demo).
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
# Program/account whose log/program signatures we treat as trigger events.
# Devnet demo: set to the same pubkey as SOLANA_DEMO_SECRET_BASE64, then run
# `npm run solana:fire-trigger` (SPL Memo with CIRCUIT_BREAKER_TRIGGERED).
SOLANA_TRIGGER_ACCOUNT=
# Optional: detector account that the policy engine writes to on Solana.
SOLANA_POLICY_ACCOUNT=
# Generated by: node ../scripts/bootstrap-solana-demo-wallet.mjs (Devnet demo wallet)
SOLANA_DEMO_SECRET_BASE64=

# --- Ika dWallet network ---
# Primary path: HTTP signing bridge (Guardian POSTs JSON, receives secp256k1 sig).
# Example: http://127.0.0.1:8790/sign  (run backend/scripts/ika-http-sign-bridge.mjs)
IKA_SIGN_HTTP_URL=
# Optional Bearer token sent as Authorization (with or without "Bearer " prefix).
IKA_SIGN_HTTP_AUTH=
# POST timeout in milliseconds (default 45000).
IKA_SIGN_HTTP_TIMEOUT_MS=45000
# dWallet id shown on proof receipts (must match your bridge / policy).
IKA_DWALLET_ID=
# Optional: forwarded to the bridge for key selection (legacy / future SDK).
IKA_DWALLET_KEY_ID=
# Legacy placeholders for a future in-process @ika.xyz/sdk wire-up (Sui client).
IKA_NETWORK_URL=https://devnet.ika.xyz
IKA_USER_SECRET=

# --- Ethereum Sepolia destination ---
# One-time deploy: from repo root, `npm run deploy:vault` (needs Sepolia ETH).
# Uses DEPLOYER_PRIVATE_KEY for gas; guardian defaults to SEPOLIA_RELAYER_PRIVATE_KEY.
DEPLOYER_PRIVATE_KEY=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Address of the deployed EvacuationVault contract on Sepolia.
EVACUATION_VAULT_ADDRESS=
# Safe destination configured on the vault (just used for display).
SAFE_DESTINATION_ADDRESS=
# OPTIONAL fallback signer for *executing* the Ika-signed transaction
# when Ika is configured to return only a raw signature. Treat this as
# a relayer key, NOT a custody key.
SEPOLIA_RELAYER_PRIVATE_KEY=

# --- Auto-replenish (judge demo loop) ---
# `evacuate()` reverts with NoFunds() (0x43f9e110) when the vault balance is 0.
# Each successful evacuate drains the vault to SAFE_DESTINATION, so to keep the
# loop running for repeated judge presses, the backend tops up the vault from
# the relayer when its balance falls below VAULT_MIN_BALANCE_WEI.
# Defaults below: top up any empty vault with 0.001 ETH. Set either to 0 to disable.
VAULT_MIN_BALANCE_WEI=1
VAULT_TOPUP_WEI=1000000000000000

# --- Demo / pacing ---
PIPELINE_TICK_MS=200
MOCK_AUTOTRIGGER_INTERVAL_MS=0
